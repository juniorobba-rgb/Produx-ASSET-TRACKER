{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Asset": {
      "title": "Asset",
      "description": "An asset to track",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "typeId": { "type": "string" },
        "typeName": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["En cours", "Correction", "Validé"] },
        "assignedUserId": { "type": ["string", "null"] },
        "assignedUserName": { "type": ["string", "null"] },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "typeId", "status"]
    },
    "AssetType": {
      "title": "AssetType",
      "description": "A type of asset",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "defaultPrice": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "defaultPrice"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/assets/{assetId}": {
      "schema": { "$ref": "#/entities/Asset" },
      "description": "Assets"
    },
    "/assetTypes/{assetTypeId}": {
      "schema": { "$ref": "#/entities/AssetType" },
      "description": "Asset types"
    }
  }
}
